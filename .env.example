# Copy to .env.local (gitignored). Never commit real values.
# Full reference with defaults and behaviour: docs/RUNBOOK.md §3.

# Database (Turso/libSQL). Omit both to fall back to a local file:./my-content.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth
# Required in production (throws if unset); dev falls back to a hardcoded dev secret.
APP_SESSION_SECRET=your-session-secret

# RESET_PIN is checked for the LITERAL STRING "true" and nothing else.
# Any other value (including "your-reset-pin") is a no-op.
# When "true", EVERY hasPinConfigured() call wipes pin_hash/pin_set_at — leave it
# set and the PIN is wiped continuously. Unset it after minting a session. Local only.
RESET_PIN=

# PIN rate limiting (all optional; defaults shown, from lib/server/auth/constants.ts).
# Values must be positive finite numbers — an invalid value throws at import.
PIN_RATE_LIMIT_MAX_ATTEMPTS=5
PIN_RATE_LIMIT_WINDOW_MS=300000
PIN_RATE_LIMIT_LOCKOUT_MS=300000
PIN_RATE_LIMIT_MAX_LOCKOUT_MS=1800000
PIN_RATE_LIMIT_MAX_TRACKED_KEYS=1000
PIN_GLOBAL_RATE_LIMIT_MAX_ATTEMPTS=100
PIN_GLOBAL_RATE_LIMIT_WINDOW_MS=600000
PIN_GLOBAL_RATE_LIMIT_LOCKOUT_MS=900000
PIN_GLOBAL_RATE_LIMIT_MAX_LOCKOUT_MS=3600000

# Only enable behind a proxy that OVERWRITES X-Forwarded-For. Default false, which
# means every caller shares the rate-limit key "shared".
TRUST_PROXY_HEADERS=false

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# ScrapeCreators (Instagram + YouTube metadata transport). Credit-based — see RUNBOOK §5.
SCRAPECREATORS_API_KEY=your-scrapecreators-api-key
SCRAPECREATORS_BASE_URL=https://api.scrapecreators.com
PROFILE_TTL_DAYS=7

# Video download cap
MAX_VIDEO_BYTES=524288000

# Instagram thumbnail proxy (optional; defaults in the proxy route)
MAX_IMAGE_PROXY_BYTES=
IMAGE_PROXY_CACHE_DIR=
IMAGE_PROXY_CACHE_TTL_DAYS=

# Ollama (optional local model)
OLLAMA_MODEL=
