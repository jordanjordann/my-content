# Database (Turso/libSQL). Omit both to fall back to a local file:./my-content.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth
APP_SESSION_SECRET=your-session-secret
RESET_PIN=your-reset-pin

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Instagram (Playwright/burner-account scraping) — retired at cutover once
# ScrapeCreators validation (#36) passes. Kept until then.
INSTAGRAM_USERNAME=your-instagram-username
INSTAGRAM_PASSWORD=your-instagram-password

# ScrapeCreators (Instagram API transport)
SCRAPECREATORS_API_KEY=your-scrapecreators-api-key
SCRAPECREATORS_BASE_URL=https://api.scrapecreators.com
PROFILE_TTL_DAYS=7
MAX_VIDEO_BYTES=524288000

# Ollama (optional local model)
OLLAMA_MODEL=
